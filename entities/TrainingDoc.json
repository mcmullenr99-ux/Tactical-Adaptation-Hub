{
  "type": "object",
  "properties": {
    "group_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "doc_type": {
      "type": "string",
      "enum": [
        "Standard Operating Procedure",
        "Tactics Techniques and Procedures",
        "Field Manual",
        "Drill",
        "Reference",
        "Other"
      ]
    },
    "file_url": {
      "type": "string"
    },
    "file_name": {
      "type": "string"
    },
    "file_size_bytes": {
      "type": "number"
    },
    "mime_type": {
      "type": "string"
    },
    "page_count": {
      "type": "number"
    },
    "word_count": {
      "type": "number"
    },
    "uploaded_by": {
      "type": "string"
    },
    "uploaded_by_username": {
      "type": "string"
    },
    "last_reviewed_at": {
      "type": "string",
      "format": "date"
    },
    "is_current": {
      "type": "boolean",
      "default": true
    },
    "depth_score": {
      "type": "number"
    },
    "ai_summary": {
      "type": "string"
    },
    "source_type": {
      "type": "string",
      "enum": [
        "upload",
        "google_doc",
        "apple_pages",
        "link"
      ],
      "default": "upload"
    },
    "source_url": {
      "type": "string",
      "description": "URL for Google Doc or external link sources"
    }
  },
  "required": [
    "group_id",
    "title"
  ],
  "name": "TrainingDoc"
}